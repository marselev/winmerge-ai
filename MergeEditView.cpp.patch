+/**
+ * @brief Perform AI Auto Merge
+ */
+void CMergeEditView::OnAIAutoMerge()
+{
+	CMergeDoc* pDoc = GetDocument();
+	if (!pDoc)
+		return;
+	
+	// Get the destination pane (current pane)
+	int dstPane = m_nThisPane;
+	
+	// Perform AI Auto Merge
+	AIAutoMergeResult result = pDoc->DoAIAutoMerge(dstPane);
+	
+	// Show result message
+	if (result.success)
+	{
+		String msg = result.message;
+		if (result.conflictCount > 0)
+		{
+			msg += _T("\n\nSome differences require manual resolution.");
+			AfxMessageBox(msg.c_str(), MB_OK | MB_ICONINFORMATION);
+		}
+		else
+		{
+			AfxMessageBox(msg.c_str(), MB_OK | MB_ICONINFORMATION);
+		}
+	}
+	else
+	{
+		AfxMessageBox(result.message.c_str(), MB_OK | MB_ICONWARNING);
+	}
+	
+	// Update the location view
+	if (pDoc->GetLocationView())
+	{
+		pDoc->GetLocationView()->Invalidate();
+	}
+}
