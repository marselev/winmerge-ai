+/**
+ * @brief Perform AI Auto Merge
+ * @param dstPane Destination pane for the merge
+ * @return Result of the AI auto merge operation
+ */
+AIAutoMergeResult CMergeDoc::DoAIAutoMerge(int dstPane)
+{
+	AIAutoMergeManager* pManager = GetAIAutoMergeManager();
+	if (!pManager)
+	{
+		AIAutoMergeResult result = { false, 0, 0, _T("AI Auto Merge manager not available") };
+		return result;
+	}
+	
+	// Ensure AI Auto Merge is enabled
+	if (!pManager->IsEnabled())
+	{
+		pManager->SetEnabled(true);
+	}
+	
+	// Perform the merge
+	AIAutoMergeResult result = pManager->PerformAutoMerge(this, dstPane);
+	
+	// Update views if merge was successful
+	if (result.success && result.mergedCount > 0)
+	{
+		ForEachView([](CMergeEditView* pView) { pView->Invalidate(); });
+		UpdateAllViews(nullptr);
+	}
+	
+	return result;
+}
+
+/**
+ * @brief Check if AI Auto Merge is enabled
+ * @return true if AI Auto Merge is enabled
+ */
+bool CMergeDoc::IsAIAutoMergeEnabled() const
+{
+	AIAutoMergeManager* pManager = GetAIAutoMergeManager();
+	return pManager && pManager->IsEnabled();
+}
